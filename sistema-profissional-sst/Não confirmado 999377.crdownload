<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='utf-8'></head><body style='font-family:Arial,sans-serif;line-height:1.6'>
      <h1 style="text-align:center;color:#1e293b">RELATÓRIO TÉCNICO DE AUDITORIA SST</h1>
      <h3 style="text-align:center;color:#475569">Checklist de Segurança do Trabalho com IA — Mentorhub</h3>
      <hr>
      <table style="width:100%;font-size:14px;margin-bottom:20px">
        <tr><td><b>Empresa:</b> MÁXIMO</td><td><b>CNPJ:</b> 08741258000167</td></tr>
        <tr><td><b>Local/Setor:</b> loja</td><td><b>Responsável:</b> Marcelo</td></tr>
